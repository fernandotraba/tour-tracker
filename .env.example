# ── API (apps/api) ────────────────────────────────────────────────────────────

# Port (Railway sets this automatically)
PORT=3000

# Traba API — Bearer token for ops-prod.traba.tech
# Ask engineering (Sumeet/Jeff) for a service account token
TRABA_API_TOKEN=

# Traba MCP URL (default is correct)
TRABA_MCP_URL=https://ops-prod.traba.tech/v1/mcp

# Google Service Account — for reading/writing the tracker sheet
# 1. Get a service account JSON from GCP (ask engineering — traba-app project)
# 2. Share the sheet with the service account email
# 3. Paste the entire JSON as a single line here
GOOGLE_SERVICE_ACCOUNT_JSON=

# Session JWT secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# ── Web (apps/web) ─────────────────────────────────────────────────────────────
# Google OAuth Client ID — create in GCP Console (traba-app project, Web application type)
# Add http://localhost:5173 and http://localhost:3000 to Authorized JavaScript Origins
VITE_GOOGLE_CLIENT_ID=
